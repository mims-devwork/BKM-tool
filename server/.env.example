# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Azure OpenAI
OPENAI_API_KEY=paste-your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://bkm-generator-resource.openai.azure.com/openai/v1

# Session token signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=replace-with-64-char-hex-string

# Optional
PORT=3000
SESSION_TTL_HOURS=8
